{
  "expo": {
    "name": "Pahadi Pharma Assistant",
    "slug": "pahadi-pharma",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pahadipharma",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan medicine packaging to identify it",
        "NSMicrophoneUsageDescription": "Speak a medicine name for quick search",
        "NSPhotoLibraryUsageDescription": "Choose a medicine photo to identify"
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#F9F9F7"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "Scan medicine packaging to identify it"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Choose a medicine photo to identify"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Speak a medicine name for quick search"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#F9F9F7"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
